rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isConversationParticipant(conversationId) {
      return isSignedIn()
        && request.auth.uid in get(
          /databases/$(database)/documents/conversations/$(conversationId)
        ).data.participants;
    }
function reviewBooking(bookingId) {
  return get(
    /databases/$(database)/documents/bookings/$(bookingId)
  );
}

    // Main user profile document
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }
// User notification history
match /users/{userId}/notifications/{notificationId} {
  allow read: if isOwner(userId);

  allow update: if isOwner(userId)
    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly(["isRead"])
    && resource.data.isRead == false
    && request.resource.data.isRead == true;

  allow create: if false;
  allow delete: if false;
}
// Push tokens for a user's own devices
match /users/{userId}/pushTokens/{tokenId} {
  allow read: if isOwner(userId);

  allow create: if isOwner(userId)
    && request.resource.data.keys().hasOnly([
      "token",
      "platform",
      "enabled",
      "createdAt",
      "updatedAt"
    ])
    && request.resource.data.keys().hasAll([
      "token",
      "platform",
      "enabled",
      "createdAt",
      "updatedAt"
    ])
    && request.resource.data.token is string
    && request.resource.data.token.size() > 0
    && request.resource.data.platform is string
    && request.resource.data.platform in [
      "ios",
      "android",
      "web"
    ]
    && request.resource.data.enabled == true
    && request.resource.data.createdAt is timestamp
    && request.resource.data.updatedAt is timestamp;

  allow update: if isOwner(userId)
    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "enabled",
        "updatedAt"
      ])
    && request.resource.data.enabled is bool
    && request.resource.data.updatedAt is timestamp
    && request.resource.data.token == resource.data.token
    && request.resource.data.platform == resource.data.platform
    && request.resource.data.createdAt == resource.data.createdAt;

  allow delete: if isOwner(userId);
}
   // Client profiles
	match /clients/{clientId} {
  allow read: if isSignedIn();
  allow create: if isOwner(clientId);
  allow update: if isOwner(clientId);
  allow delete: if false;

  // Private client notes
  match /notes/{noteId} {
    allow read: if isOwner(clientId);
    allow create: if isOwner(clientId);
    allow update: if isOwner(clientId);
    allow delete: if isOwner(clientId);
  }
    match /hairProfiles/{profileId} {
    allow read: if isOwner(clientId);
    allow update: if isOwner(clientId);
    allow create: if false;
    allow delete: if false;
  }

}

    // Barber profiles
match /barbers/{barberId} {
  allow read: if isSignedIn();

  allow create: if isOwner(barberId);

  allow update: if isOwner(barberId)
    || (
      isSignedIn()
      && request.resource.data.diff(resource.data).changedKeys()
        .hasOnly(["rating", "reviewCount", "updatedAt"])
    );

  allow delete: if false;
}
    // Bookings
match /bookings/{bookingId} {
  allow read: if isSignedIn();

  allow create: if isSignedIn()
    && request.auth.uid == request.resource.data.clientId;

  allow update: if isSignedIn()
    && (
      request.auth.uid == resource.data.clientId ||
      request.auth.uid == resource.data.barberId
    );

  allow delete: if false;
}

    // Conversations
    match /conversations/{conversationId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants;

      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow delete: if false;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isConversationParticipant(conversationId);

        allow create: if isConversationParticipant(conversationId)
          && request.resource.data.senderId == request.auth.uid;

        allow update, delete: if false;
      }
    }
// Reviews
match /reviews/{reviewId} {
  allow read: if isSignedIn();

  allow create: if isSignedIn()
    && request.resource.data.bookingId is string
    && request.resource.data.clientId == request.auth.uid

    // The booking must exist.
    && exists(
      /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
    )

    // The booking must be completed.
    && reviewBooking(request.resource.data.bookingId).data.status == "completed"

    // The logged-in user must be the booking client.
    && reviewBooking(request.resource.data.bookingId).data.clientId == request.auth.uid

    // Review data must match the booking data.
    && request.resource.data.clientId ==
      reviewBooking(request.resource.data.bookingId).data.clientId
    && request.resource.data.barberId ==
      reviewBooking(request.resource.data.bookingId).data.barberId

    // Basic rating validation.
    && request.resource.data.rating is number
    && request.resource.data.rating >= 1
    && request.resource.data.rating <= 5
    
&& request.resource.data.comment is string
&& request.resource.data.comment.size() <= 1000
    // Keep the document shape controlled.
    && request.resource.data.keys().hasOnly([
      "bookingId",
      "clientId",
      "barberId",
      "clientName",
      "barberName",
      "businessName",
      "rating",
      "comment",
      "createdAt",
      "updatedAt"
    ]);

  allow update: if false;
  allow delete: if false;
}
    // Deny anything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
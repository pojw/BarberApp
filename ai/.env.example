# BarberApp AI Backend Environment

ENVIRONMENT=development
AUTH_MODE=mock
AI_PROFILE_STORAGE_ENABLED=false
CORS_ORIGINS=*

# Firebase Admin config
# For this project, we are using environment variables instead of a local JSON file.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Optional alternative local setup, not used right now:
# FIREBASE_CREDENTIALS_PATH=./service-account.json